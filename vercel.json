{
  "redirects": [
    { "source": "/en",  "destination": "/",        "permanent": true },
    { "source": "/zh",  "destination": "/zh-cn/", "permanent": true },
    { "source": "/en/:path*", "destination": "/:path*",    "permanent": true },
    { "source": "/zh/:path*", "destination": "/zh-cn/:path*", "permanent": true },
    { "source": "/forum", "destination": "/community/", "permanent": true },
    { "source": "/forum/", "destination": "/community/", "permanent": true },
    { "source": "/zh-cn/forum", "destination": "/zh-cn/community/", "permanent": true },
    { "source": "/zh-cn/forum/", "destination": "/zh-cn/community/", "permanent": true },
    { "source": "/zh-tw/forum", "destination": "/zh-tw/community/", "permanent": true },
    { "source": "/zh-tw/forum/", "destination": "/zh-tw/community/", "permanent": true },
    { "source": "/club", "destination": "/agent-club/", "permanent": true },
    { "source": "/club/", "destination": "/agent-club/", "permanent": true },
    { "source": "/zh-cn/club", "destination": "/zh-cn/agent-club/", "permanent": true },
    { "source": "/zh-cn/club/", "destination": "/zh-cn/agent-club/", "permanent": true },
    { "source": "/zh-tw/club", "destination": "/zh-tw/agent-club/", "permanent": true },
    { "source": "/zh-tw/club/", "destination": "/zh-tw/agent-club/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' https://api.dwac.net; frame-ancestors 'self'" }
      ]
    }
  ]
}
